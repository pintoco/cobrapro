# ─────────────────────────────────────────────────────────────────────────────
# CobranzaPro SaaS — Environment Variables Template
#
# LOCAL DOCKER:  Copy to .env in the project root and adjust values.
# RAILWAY:       Set each variable in the Railway dashboard per service.
#                Variables marked [Railway-auto] are injected by Railway.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
APP_NAME=CobranzaPro

# PORT is injected automatically by Railway — do NOT set it manually there.
# For local Docker it defaults to 3001 (backend) / 3000 (frontend).
# PORT=3001   # [Railway-auto]

# ── PostgreSQL (local Docker only) ────────────────────────────────────────────
# On Railway, add a PostgreSQL plugin — DATABASE_URL is injected automatically.
POSTGRES_USER=cobrapro
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=cobrapro_prod
POSTGRES_PORT=5432

# ── Database URL ──────────────────────────────────────────────────────────────
# [Railway-auto] when PostgreSQL plugin is attached to the backend service.
# For local Docker, docker-compose overrides this with the service name.
DATABASE_URL=postgresql://cobrapro:change_me_strong_password@localhost:5432/cobrapro_prod?schema=public

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_at_least_64_random_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_different_64_random_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Railway frontend URL here in production.
# Example: https://cobrapro-frontend.up.railway.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── SMTP (Email reminders) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_gmail
SMTP_FROM_NAME=CobranzaPro
SMTP_FROM_EMAIL=noreply@cobrapro.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Must be the public backend URL — reachable from the user's browser.
# Railway example: https://cobrapro-backend.up.railway.app
# This is a BUILD-TIME variable for Next.js — set it before building.
NEXT_PUBLIC_API_URL=http://localhost:3001
