generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN_EMPRESA
  OPERADOR
  CLIENTE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DocumentType {
  DNI
  RUC
  PASSPORT
  CE
  OTHER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CREDIT_CARD
  DEBIT_CARD
  YAPE
  PLIN
  OTHER
}

enum PaymentStatus {
  COMPLETED
  VOIDED
}

enum NotificationType {
  REMINDER_3_DAYS_BEFORE
  REMINDER_1_DAY_BEFORE
  REMINDER_DUE_TODAY
  REMINDER_1_DAY_OVERDUE
  REMINDER_3_DAYS_OVERDUE
  REMINDER_7_DAYS_OVERDUE
  REMINDER_CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// ─────────────────────────────────────────
// COMPANY (Tenant principal)
// ─────────────────────────────────────────

model Company {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  ruc         String?       @unique
  email       String
  phone       String?
  address     String?
  logo        String?
  status      CompanyStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  users         User[]
  clients       Client[]
  invoices      Invoice[]
  payments      Payment[]
  notifications Notification[]

  @@map("companies")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  firstName      String
  lastName       String
  role           Role      @default(OPERADOR)
  isActive       Boolean   @default(true)
  refreshToken   String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([companyId])
  @@map("users")

  payments      Payment[]
}

// ─────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────

model Client {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  phone          String?
  documentType   DocumentType @default(DNI)
  documentNumber String?
  address        String?
  city           String?
  country        String       @default("PE")
  notes          String?
  status         ClientStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([email, companyId])
  @@unique([documentNumber, companyId])
  @@index([companyId])
  @@index([status])
  @@map("clients")

  invoices      Invoice[]
  payments      Payment[]
  notifications Notification[]
}

// ─────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String
  status          InvoiceStatus @default(PENDING)
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  subtotal        Decimal       @db.Decimal(12, 2)
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  currency        String        @default("PEN")
  notes           String?
  paidAt          DateTime?
  cancelledAt     DateTime?
  overdueAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)

  items           InvoiceItem[]
  payments        Payment[]
  notifications   Notification[]

  @@unique([invoiceNumber, companyId])
  @@index([companyId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

// ─────────────────────────────────────────
// INVOICE ITEM (líneas de factura)
// ─────────────────────────────────────────

model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @default(now())
  method        PaymentMethod @default(BANK_TRANSFER)
  status        PaymentStatus @default(COMPLETED)
  reference     String?
  notes         String?
  voidedAt      DateTime?
  voidReason    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)

  createdById   String?
  createdBy     User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([invoiceId])
  @@index([clientId])
  @@index([status])
  @@index([paymentDate])
  @@map("payments")
}

// ─────────────────────────────────────────
// NOTIFICATION (audit trail de recordatorios)
// ─────────────────────────────────────────

model Notification {
  id           String             @id @default(cuid())
  type         NotificationType
  status       NotificationStatus @default(PENDING)
  channel      String             @default("EMAIL")
  recipientEmail String
  subject      String
  body         String             @db.Text
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime           @default(now())

  companyId    String
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoiceId    String
  invoice      Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  clientId     String
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, type])
  @@index([companyId])
  @@index([invoiceId])
  @@index([status])
  @@map("notifications")
}
