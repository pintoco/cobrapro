generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN_EMPRESA
  OPERADOR
  CLIENTE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DocumentType {
  RUT
  PASAPORTE
  OTRO
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

enum InvoiceDocumentType {
  FACTURA
  BOLETA
  NOTA_COBRO
  OTRO
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CREDIT_CARD
  DEBIT_CARD
  WEBPAY
  TRANSFERENCIA_ELECTRONICA
  OTHER
}

enum PaymentStatus {
  COMPLETED
  VOIDED
}

enum NotificationType {
  REMINDER_3_DAYS_BEFORE
  REMINDER_1_DAY_BEFORE
  REMINDER_DUE_TODAY
  REMINDER_1_DAY_OVERDUE
  REMINDER_3_DAYS_OVERDUE
  REMINDER_7_DAYS_OVERDUE
  REMINDER_CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum PaymentPromiseStatus {
  PENDIENTE
  CUMPLIDA
  INCUMPLIDA
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  SEND_NOTIFICATION
  IMPORT
}

// ─────────────────────────────────────────
// COMPANY (Tenant principal)
// ─────────────────────────────────────────

model Company {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  // Campos Chile
  rutEmpresa       String?       @unique
  razonSocial      String?
  nombreFantasia   String?
  giro             String?
  direccion        String?
  comuna           String?
  ciudad           String?
  telefono         String?
  email            String
  emailFacturacion String?
  logo             String?
  // Legacy (compatibilidad)
  ruc              String?       @unique
  address          String?
  phone            String?
  status           CompanyStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  users            User[]
  clients          Client[]
  invoices         Invoice[]
  payments         Payment[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  subscription     CompanySubscription?
  messageTemplates MessageTemplate[]
  collectionNotes  CollectionNote[]

  @@map("companies")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  firstName       String
  lastName        String
  role            Role      @default(OPERADOR)
  isActive        Boolean   @default(true)
  refreshToken    String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  companyId       String?
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  payments        Payment[]
  auditLogs       AuditLog[]
  collectionNotes CollectionNote[]

  @@index([email])
  @@index([companyId])
  @@map("users")
}

// ─────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────

model Client {
  id                String       @id @default(cuid())
  // Nombres de persona o razón social resumida
  firstName         String
  lastName          String
  // Campos Chile
  rut               String?
  razonSocial       String?
  nombreFantasia    String?
  giro              String?
  contactoPrincipal String?
  // Contacto
  email             String
  phone             String?
  documentType      DocumentType @default(RUT)
  documentNumber    String?
  address           String?
  ciudad            String?
  comuna            String?
  // Legacy
  city              String?
  country           String       @default("CL")
  notes             String?
  status            ClientStatus @default(ACTIVE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  companyId         String
  company           Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoices          Invoice[]
  payments          Payment[]
  notifications     Notification[]
  collectionNotes   CollectionNote[]

  @@unique([email, companyId])
  @@unique([documentNumber, companyId])
  @@index([companyId])
  @@index([status])
  @@map("clients")
}

// ─────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────

model Invoice {
  id                 String               @id @default(cuid())
  invoiceNumber      String
  folio              String?
  tipoDocumento      InvoiceDocumentType  @default(FACTURA)
  status             InvoiceStatus        @default(PENDING)
  issueDate          DateTime             @default(now())
  dueDate            DateTime
  subtotal           Decimal              @db.Decimal(12, 2)
  // IVA chileno (default 19%)
  ivaRate            Decimal              @default(19) @db.Decimal(5, 2)
  neto               Decimal              @default(0) @db.Decimal(12, 2)
  iva                Decimal              @default(0) @db.Decimal(12, 2)
  // Legacy (compatibilidad)
  taxRate            Decimal              @default(0) @db.Decimal(5, 2)
  taxAmount          Decimal              @default(0) @db.Decimal(12, 2)
  discount           Decimal              @default(0) @db.Decimal(12, 2)
  total              Decimal              @db.Decimal(12, 2)
  currency           String               @default("CLP")
  notes              String?
  // Promesa de pago
  fechaPromesaPago   DateTime?
  comentarioPromesa  String?
  estadoPromesa      PaymentPromiseStatus?
  // Timestamps
  paidAt             DateTime?
  cancelledAt        DateTime?
  overdueAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  companyId          String
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  clientId           String
  client             Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)

  items              InvoiceItem[]
  payments           Payment[]
  notifications      Notification[]
  collectionNotes    CollectionNote[]

  @@unique([invoiceNumber, companyId])
  @@index([companyId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

// ─────────────────────────────────────────
// INVOICE ITEM
// ─────────────────────────────────────────

model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(12, 2)
  paymentDate DateTime      @default(now())
  method      PaymentMethod @default(BANK_TRANSFER)
  status      PaymentStatus @default(COMPLETED)
  reference   String?
  notes       String?
  voidedAt    DateTime?
  voidReason  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([invoiceId])
  @@index([clientId])
  @@index([status])
  @@index([paymentDate])
  @@map("payments")
}

// ─────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────

model Notification {
  id             String              @id @default(cuid())
  type           NotificationType
  status         NotificationStatus  @default(PENDING)
  channel        NotificationChannel @default(EMAIL)
  recipientEmail String
  recipientPhone String?
  subject        String
  body           String              @db.Text
  sentAt         DateTime?
  errorMessage   String?
  createdAt      DateTime            @default(now())

  companyId      String
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoiceId      String
  invoice        Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  clientId       String
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, type])
  @@index([companyId])
  @@index([invoiceId])
  @@index([status])
  @@map("notifications")
}

// ─────────────────────────────────────────
// COLLECTION NOTE (notas internas de cobranza)
// ─────────────────────────────────────────

model CollectionNote {
  id        String   @id @default(cuid())
  note      String   @db.Text
  createdAt DateTime @default(now())

  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([companyId])
  @@map("collection_notes")
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([entity])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// SUBSCRIPTION PLAN
// ─────────────────────────────────────────

model SubscriptionPlan {
  id                   String   @id @default(cuid())
  name                 String   @unique
  priceCLP             Int      @default(0)
  maxUsers             Int      @default(5)
  maxClients           Int      @default(100)
  maxInvoicesPerMonth  Int      @default(50)
  allowWhatsApp        Boolean  @default(false)
  allowExcelImport     Boolean  @default(false)
  allowAdvancedReports Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  subscriptions        CompanySubscription[]

  @@map("subscription_plans")
}

// ─────────────────────────────────────────
// COMPANY SUBSCRIPTION
// ─────────────────────────────────────────

model CompanySubscription {
  id                 String             @id @default(cuid())
  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  companyId          String             @unique
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  planId             String
  plan               SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("company_subscriptions")
}

// ─────────────────────────────────────────
// MESSAGE TEMPLATE (WhatsApp / Email personalizado)
// ─────────────────────────────────────────

model MessageTemplate {
  id        String              @id @default(cuid())
  name      String
  channel   NotificationChannel @default(EMAIL)
  type      NotificationType
  subject   String?
  body      String              @db.Text
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  companyId String
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, channel, type])
  @@index([companyId])
  @@map("message_templates")
}
